# Copy to `.env` (gitignored) to override the app's database for docker-compose.
# Leave unset to use the bundled local `db` MySQL container.
#
# Example: point at a managed cloud DB (Aiven) over TLS.
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=defaultdb
DB_USER=your-user
DB_PASS=your-password
DB_SSL=1
